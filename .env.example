# Deployed via deploy.js (Twilio Serverless REST API directly — no CLI
# plugin). It reads this file and pushes each var into the deployed
# Function's environment. Your Twilio Account SID/Auth Token are NOT needed
# here: Twilio Functions authenticate as your own account automatically via
# context.getTwilioClient(). (deploy.js itself needs TWILIO_SID/TWILIO_TOKEN
# as separate shell env vars to authenticate the deploy — see README.)

# Supabase project — used via @supabase/supabase-js instead of a raw
# Postgres connection string. SUPABASE_SECRET_KEY is the service-role key,
# which bypasses row-level security, so keep it out of git.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Anthropic API key — create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# The Twilio number this deploys behind — used as the "from" number when sending replies.
TWILIO_PHONE_NUMBER=+15551234567

# Shared-secret query param that gates /dashboard (e.g. https://.../dashboard?key=THIS).
# Pick a long random value. Twilio Functions don't reliably expose request
# headers, so this stands in for HTTP Basic Auth — keep the URL private.
DASHBOARD_SECRET=

# Set to "true" once functions/persona.js is configured and you're ready to
# let "routine" replies send without review. Defaults to off.
AUTO_SEND_ENABLED=false

# SendGrid delivery settings.
SENDGRID_API_KEY=
FROM_EMAIL=devin@luxstudios.shop
FORWARD_EMAIL=deviincistudio@icloud.com

# NOTE: the reply persona/boundaries live in functions/persona.js, not here —
# Twilio Function env var values are capped at 450 bytes, too small for a
# full persona. Edit that file directly to change tone/pricing/boundaries.
