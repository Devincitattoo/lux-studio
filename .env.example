# Example environment variables for lux-studio
# Copy this to .env and replace the values with your own live keys and sender settings.

# Stripe payment integration
STRIPE_SECRET_KEY=sk_test_your_key_here

# Live data mode
LIVE_DISCOVERY=true
LIVE_MESSAGING=true
LIVE_REPLIES=true
LEAD_SOURCE_PROVIDER=apify-airbnb
APIFY_TOKEN=your_apify_token_here
APIFY_TASK_ID=your_apify_task_id_here
APIFY_DATASET_ID=your_apify_dataset_id_here
APIFY_INPUT='{"query":"luxury vacation rental Miami Beach, Florida"}'
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_SENDER=your_verified_sendgrid_email@example.com
REPLY_SOURCE_URL=https://your-reply-endpoint.example.com/replies
USE_VIDEO_GENERATION=true
HIGGSFIELD_API_KEY=your_higgsfield_api_key_here
HIGGSFIELD_PROJECT_ID=your_higgsfield_project_id_here
HIGGSFIELD_MODEL=higgsfield-mcp-video
HIGGSFIELD_CALLBACK_URL=https://your-callback.example.com/higgsfield
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
LANDING_PAGE_URL=https://your-lux-studio-landing-page.example.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_SENDER=+15551234567
AIRBNB_API_TOKEN=your_airbnb_api_token_here
AIRBNB_BUSINESS_PROFILE_ID=your_airbnb_business_profile_id_here
MCP_SERVER_URL=https://your-mcp-server.example.com
MCP_API_KEY=your_mcp_api_key_here
LIVE_DASHBOARD_URL=https://your-live-dashboard.example.com

# Local behavior
DRY_RUN=false
TEST_MODE=false
