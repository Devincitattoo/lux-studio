# Local Express server config
PORT=3000

# Public base URL — used for Square redirect and webhooks.
# In development with ngrok, set this to your ngrok HTTPS URL.
BASE_URL=http://localhost:3000

# Database — SQLite file path (created automatically on first run)
DATABASE_PATH=./data/lux-studio.db

# Venice AI — get API key at https://venice.ai/settings/api
VENICE_API_KEY=
VENICE_MODEL=venice-uncensored

# Optional AI cost estimates (per 1M tokens) used for dashboard ROI calculations.
# Defaults are conservative placeholders; update with your Venice model pricing.
AI_INPUT_COST_PER_1M=0.25
AI_OUTPUT_COST_PER_1M=0.75

# Brevo — messaging platform for email. Get API key at
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Brevo SMS sender. SMS is disabled for now, but keep this for later.
# In the US this must be a Brevo phone number in E.164 format.
BREVO_SMS_SENDER=+15551234567

# Outbound / forward email addresses
FROM_EMAIL=devin@luxstudios.shop
FORWARD_EMAIL=forward@example.com

# Square payments — get credentials from https://developer.squareup.com/
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_CURRENCY=USD
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Shared-secret query param that gates /dashboard, /sms, /email-inbound,
# and /dashboard-action. Pick a long random value and keep the URLs private.
DASHBOARD_SECRET=

# Set to "true" once the Venice personas are tuned and you're ready to let
# "routine" replies send without review. Defaults to off.
AUTO_SEND_ENABLED=false
