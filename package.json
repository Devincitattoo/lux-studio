{
  "name": "lux-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/index.js",
    "run-once": "RUN_ONCE=true tsx src/index.ts",
    "dry-run": "DRY_RUN=true RUN_ONCE=true tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@supabase/supabase-js": "^3.12.0",
    "stripe": "^12.0.0",
    "twilio": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.18.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "eslint": "^8.57.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vitest": "^1.4.0"
  }
}
