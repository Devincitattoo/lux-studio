{
  "name": "reply-assistant",
  "version": "0.4.0",
  "description": "Venice-powered auto-reply for Lux Studio, running locally on Express. Brevo for email, SQLite for persistence, Square for payments.",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "tunnel": "bin/cloudflared tunnel --config cloudflared-config.yml run",
    "dev": "node --watch server.js",
    "prod": "./start.sh",
    "stop": "./stop.sh"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "square": "^38.0.0",
    "uuid": "^10.0.0"
  }
}
